# Runtime state (written by hooks/installer, never committed)
# Use negation so .gitkeep sentinels remain tracked for WP-01b skeleton.
.wow-harness/install-staging/*
!.wow-harness/install-staging/.gitkeep
.wow-harness/metrics/*
!.wow-harness/metrics/.gitkeep
.wow-harness/proposals/*
!.wow-harness/proposals/.gitkeep
.wow-harness/guard/*
!.wow-harness/guard/.gitkeep
.wow-harness/active-review-agents/*
!.wow-harness/active-review-agents/.gitkeep
.wow-harness/tasks/*
!.wow-harness/tasks/.gitkeep
.wow-harness/install-log.jsonl
.wow-harness/install-trust-token.json
.wow-harness/trust-status.json
.wow-harness/state/

# .towow/ runtime state — created when hooks fire after install. Schema
# files like .towow/inbox/schema/*.json are tracked above; everything
# else under .towow/ is hook output and never committed.
.towow/guard/
.towow/logs/
.towow/metrics/
.towow/proposals/
.towow/inbox/main/
.towow/inbox/window-*/
.towow/log/

# Secrets / env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
